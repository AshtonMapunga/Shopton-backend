<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>Order Confirmation</title>
</head>
<body style="font-family: Arial, sans-serif; background:#f5f5f5; padding:20px;">
  <div style="max-width:600px; background:#ffffff; margin:auto; padding:20px; border-radius:8px;">

    <div style="text-align:center;">
      <img src="<%= logoUrl %>" alt="Shoptoo Logo" width="150" />
    </div>

    <h2 style="color:#333;">Hello <%= name %>,</h2>

    <p>Thank you for your order!</p>

    <p><strong>Order ID:</strong> <%= orderId %></p>
    <p><strong>Total Amount:</strong> $<%= total %></p>

    <hr />

    <p>We will notify you once your order is delivered.</p>

    <p style="margin-top:30px;">
      Regards,<br/>
      <strong>Shoptoo Team</strong>
    </p>

  </div>
</body>
</html>